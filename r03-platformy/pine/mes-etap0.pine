//@version=6
indicator("Bractwo Rynku — MES Etap 0", shorttitle="MES_E0", overlay=true, max_labels_count=1)

// --- Parametry ---
emaLen1    = input.int(8,    "EMA szybka")
emaLen2    = input.int(20,   "EMA srednia")
emaLen3    = input.int(50,   "EMA wolna")
emaLen4    = input.int(200,  "EMA dlugoterminowa")
atrLen     = input.int(14,   "ATR okres")
rvolLen    = input.int(20,   "RVOL srednia wolumenu")
showTable  = input.bool(true, "Pokaz tabele danych")
showBands  = input.bool(true, "Pokaz wstegi VWAP")
bandDev1   = input.float(1.0, "VWAP odchylenie 1")
bandDev2   = input.float(2.0, "VWAP odchylenie 2")

// --- Obliczenia EMA/ATR/RVOL ---
emaVal1   = ta.ema(close, emaLen1)
emaVal2   = ta.ema(close, emaLen2)
emaVal3   = ta.ema(close, emaLen3)
emaVal4   = ta.ema(close, emaLen4)
atrVal    = ta.atr(atrLen)
rvolVal   = nz(volume / ta.sma(volume, rvolLen), 0)

// --- VWAP z odchyleniem standardowym (reset per sesja) ---
vwapVal    = ta.vwap
sumVol     = ta.cum(volume)
sumVolSrc  = ta.cum(volume * close)
sumVolSrc2 = ta.cum(volume * close * close)

isNewSession = ta.change(time("D")) != 0
var float cumVol     = 0.0
var float cumVolSrc  = 0.0
var float cumVolSrc2 = 0.0

if isNewSession
    cumVol     := volume
    cumVolSrc  := volume * close
    cumVolSrc2 := volume * close * close
else
    cumVol     += volume
    cumVolSrc  += volume * close
    cumVolSrc2 += volume * close * close

vwapCalc = cumVol > 0 ? cumVolSrc / cumVol : close
variance = cumVol > 0 ? math.max(cumVolSrc2 / cumVol - vwapCalc * vwapCalc, 0) : 0
stdev    = math.sqrt(variance)

vwapUpper1 = vwapCalc + stdev * bandDev1
vwapLower1 = vwapCalc - stdev * bandDev1
vwapUpper2 = vwapCalc + stdev * bandDev2
vwapLower2 = vwapCalc - stdev * bandDev2

// --- VWAP wykresy ---
pVwap   = plot(vwapCalc, title="VWAP",         color=color.blue,                          linewidth=2)
pVwapU1 = plot(showBands ? vwapUpper1 : na, title="VWAP_Upper1", color=color.new(color.blue, 70), linewidth=1)
pVwapL1 = plot(showBands ? vwapLower1 : na, title="VWAP_Lower1", color=color.new(color.blue, 70), linewidth=1)
pVwapU2 = plot(showBands ? vwapUpper2 : na, title="VWAP_Upper2", color=color.new(color.blue, 85), linewidth=1)
pVwapL2 = plot(showBands ? vwapLower2 : na, title="VWAP_Lower2", color=color.new(color.blue, 85), linewidth=1)

fill(pVwapU1, pVwapL1, color=color.new(color.blue, 75), title="VWAP 1 sigma")
fill(pVwapU2, pVwapU1, color=color.new(color.blue, 85), title="VWAP 2 sigma gora")
fill(pVwapL1, pVwapL2, color=color.new(color.blue, 85), title="VWAP 2 sigma dol")

// --- EMA ---
plot(emaVal1, title="EMA_8",   color=color.yellow,  linewidth=1)
plot(emaVal2, title="EMA_20",  color=color.orange,  linewidth=1)
plot(emaVal3, title="EMA_50",  color=color.red,     linewidth=1)
plot(emaVal4, title="EMA_200", color=color.black,   linewidth=1)

// --- ATR i RVOL (ukryte, widoczne w CSV i Data Window) ---
plot(atrVal,  title="ATR_14",  color=color.green, display=display.data_window)
plot(rvolVal, title="RVOL",    display=display.data_window)

// --- Cross-asset (ukryte, widoczne w CSV i Data Window) ---
vixClose  = request.security("CBOE:VIX",       timeframe.period, close)
nqClose   = request.security("CME_MINI:NQ1!",  timeframe.period, close)
rtyClose  = request.security("CME_MINI:RTY1!", timeframe.period, close)
us10y     = request.security("TVC:US10Y",      timeframe.period, close)
dxyClose  = request.security("TVC:DXY",        timeframe.period, close)

plot(vixClose, title="VIX",   display=display.data_window)
plot(nqClose,  title="NQ",    display=display.data_window)
plot(rtyClose, title="RTY",   display=display.data_window)
plot(us10y,    title="US10Y", display=display.data_window)
plot(dxyClose, title="DXY",   display=display.data_window)

// --- Tabela na wykresie ---
var tbl = table.new(position.top_right, 2, 17, bgcolor=color.new(color.black, 20), border_width=1)

if showTable and barstate.islast
    table.cell(tbl, 0, 0, "Pole",        text_color=color.white,  text_size=size.small, text_halign=text.align_left)
    table.cell(tbl, 1, 0, "Wartosc",     text_color=color.white,  text_size=size.small, text_halign=text.align_right)
    // OHLCV
    table.cell(tbl, 0, 1, "Open",        text_color=color.white,  text_size=size.small, text_halign=text.align_left)
    table.cell(tbl, 1, 1, str.tostring(open,  "#.##"),  text_color=color.white,  text_size=size.small, text_halign=text.align_right)
    table.cell(tbl, 0, 2, "High",        text_color=color.white,  text_size=size.small, text_halign=text.align_left)
    table.cell(tbl, 1, 2, str.tostring(high,  "#.##"),  text_color=color.white,  text_size=size.small, text_halign=text.align_right)
    table.cell(tbl, 0, 3, "Low",         text_color=color.white,  text_size=size.small, text_halign=text.align_left)
    table.cell(tbl, 1, 3, str.tostring(low,   "#.##"),  text_color=color.white,  text_size=size.small, text_halign=text.align_right)
    table.cell(tbl, 0, 4, "Close",       text_color=color.white,  text_size=size.small, text_halign=text.align_left)
    table.cell(tbl, 1, 4, str.tostring(close, "#.##"),  text_color=color.white,  text_size=size.small, text_halign=text.align_right)
    table.cell(tbl, 0, 5, "Volume",      text_color=color.white,  text_size=size.small, text_halign=text.align_left)
    table.cell(tbl, 1, 5, str.tostring(volume, "#"),     text_color=color.white,  text_size=size.small, text_halign=text.align_right)
    // Wskazniki
    table.cell(tbl, 0, 6, "VWAP",        text_color=color.white,  text_size=size.small, text_halign=text.align_left)
    table.cell(tbl, 1, 6, str.tostring(vwapCalc, "#.##"), text_color=color.aqua,   text_size=size.small, text_halign=text.align_right)
    table.cell(tbl, 0, 7, "EMA 8",       text_color=color.white,  text_size=size.small, text_halign=text.align_left)
    table.cell(tbl, 1, 7, str.tostring(emaVal1, "#.##"), text_color=color.yellow,  text_size=size.small, text_halign=text.align_right)
    table.cell(tbl, 0, 8, "EMA 20",      text_color=color.white,  text_size=size.small, text_halign=text.align_left)
    table.cell(tbl, 1, 8, str.tostring(emaVal2, "#.##"), text_color=color.orange,  text_size=size.small, text_halign=text.align_right)
    table.cell(tbl, 0, 9, "EMA 50",      text_color=color.white,  text_size=size.small, text_halign=text.align_left)
    table.cell(tbl, 1, 9, str.tostring(emaVal3, "#.##"), text_color=color.red,     text_size=size.small, text_halign=text.align_right)
    table.cell(tbl, 0, 10, "EMA 200",    text_color=color.white,  text_size=size.small, text_halign=text.align_left)
    table.cell(tbl, 1, 10, str.tostring(emaVal4, "#.##"), text_color=color.white,  text_size=size.small, text_halign=text.align_right)
    table.cell(tbl, 0, 11, "ATR / RVOL", text_color=color.white,  text_size=size.small, text_halign=text.align_left)
    table.cell(tbl, 1, 11, str.tostring(atrVal, "#.##") + " / " + str.tostring(rvolVal, "#.##"), text_color=color.green, text_size=size.small, text_halign=text.align_right)
    // Cross-asset
    table.cell(tbl, 0, 12, "--- CROSS ---", text_color=color.gray, text_size=size.small, text_halign=text.align_left)
    table.cell(tbl, 1, 12, "",               text_color=color.gray, text_size=size.small, text_halign=text.align_right)
    table.cell(tbl, 0, 13, "VIX",        text_color=color.white,  text_size=size.small, text_halign=text.align_left)
    table.cell(tbl, 1, 13, str.tostring(vixClose, "#.##"), text_color=color.fuchsia, text_size=size.small, text_halign=text.align_right)
    table.cell(tbl, 0, 14, "NQ",         text_color=color.white,  text_size=size.small, text_halign=text.align_left)
    table.cell(tbl, 1, 14, str.tostring(nqClose, "#.##"),  text_color=color.lime,    text_size=size.small, text_halign=text.align_right)
    table.cell(tbl, 0, 15, "RTY",        text_color=color.white,  text_size=size.small, text_halign=text.align_left)
    table.cell(tbl, 1, 15, str.tostring(rtyClose, "#.##"), text_color=color.lime,    text_size=size.small, text_halign=text.align_right)
    table.cell(tbl, 0, 16, "US10Y/DXY",  text_color=color.white,  text_size=size.small, text_halign=text.align_left)
    table.cell(tbl, 1, 16, str.tostring(us10y, "#.##") + " / " + str.tostring(dxyClose, "#.##"), text_color=color.silver, text_size=size.small, text_halign=text.align_right)
